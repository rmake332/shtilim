# Copy this file to .env.local and fill in the values.
# .env.local is git-ignored — NEVER commit the real token.

# Airtable Personal Access Token (server-side only, never NEXT_PUBLIC_)
AIRTABLE_TOKEN=

# Airtable base id for תשפ"ז
AIRTABLE_BASE_ID=appKlvldLrk14ird8

# Set to 1 to use local mock fixtures instead of hitting Airtable (development)
AIRTABLE_MOCK=0

# Secret used to sign/verify institution tokens (generate a long random string)
TOKEN_SECRET=

# Log level: debug | info | warn | error
LOG_LEVEL=info

# Make.com webhook fired on every position submit/edit (optional — has a default).
SUBMIT_POSITION_WEBHOOK_URL=https://hook.eu2.make.com/gwynlqfizihyw5xr2pugvy2tthh0v1st

# Make.com webhook for developer error alerts (Airtable-write / Make-webhook failures).
# The scenario behind it appends a row to a Google Sheet and emails the developer.
# If empty, alerts are only written to the server log.
ERROR_WEBHOOK_URL=
